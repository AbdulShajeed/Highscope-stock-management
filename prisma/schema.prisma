generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  isDeleted   Int          @default(0)
  deletedAt   String?
  deleteReason String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  stockItems  StockItem[]
  customerPOs CustomerPO[]
  bookings    Booking[]
}

model StockItem {
  id                String          @id @default(cuid())
  itemCode          String          @unique
  description       String
  detailedDescription String?
  make              String?
  ratePerPcs        Float?
  location          String?
  incomingQty       Int             @default(0)
  soldQty           Int             @default(0)
  finalQty          Int             @default(0)
  totalValue        Float?
  reorderLevel      Int?
  notes             String?
  oldPrice          Float?
  oldQty            Int?
  newPrice          Float?
  newQty            Int?
  isSplit           Int             @default(0)
  sortOrder         Int             @default(0)
  categoryId        String
  category          Category        @relation(fields: [categoryId], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  stockMovements    StockMovement[]
  monthlyStocks     MonthlyStock[]
  bookings          Booking[]
  poLineItems       POLineItem[]
}

model StockMovement {
  id            String      @id @default(cuid())
  movementType  String
  quantity      Int
  projectCode   String?
  customerName  String?
  employee      String?
  poNumber      String?
  sellingPrice  Float?
  totalAmount   Float?
  notes         String?
  stockItemId   String
  stockItem     StockItem   @relation(fields: [stockItemId], references: [id])
  movementDate  DateTime    @default(now())
  createdAt     DateTime    @default(now())
}

model Project {
  id            String      @id @default(cuid())
  code          String      @unique
  name          String?
  customerName  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model MonthlyStock {
  id            String      @id @default(cuid())
  stockItemId   String
  month         String
  year          Int
  openingQty    Int         @default(0)
  incomingQty   Int         @default(0)
  soldQty       Int         @default(0)
  closingQty    Int         @default(0)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  stockItem     StockItem   @relation(fields: [stockItemId], references: [id])
  @@unique([stockItemId, month, year])
}

model Booking {
  id              String      @id @default(cuid())
  stockItemId     String
  categoryId      String
  month           String
  year            Int
  quantityBooked  Int
  projectNumber   String?
  engineerName    String?
  bookingDate     String?
  notes           String?
  status          String      @default("In Store")
  isDeleted       Int         @default(0)
  deletedAt       String?
  deletedBy       String?
  deleteReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  stockItem       StockItem   @relation(fields: [stockItemId], references: [id])
  category        Category    @relation(fields: [categoryId], references: [id])
}

model PurchaseOrder {
  id              String          @id @default(cuid())
  poNumber        String
  poReleasedDate  String?
  vendor          String?
  totalValue      Float           @default(0)
  leadTime        String?
  status          String          @default("Not Delivered")
  deliveryDate    String?
  categoryId      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  lineItems       POLineItem[]
}

model POLineItem {
  id                String          @id @default(cuid())
  poId              String
  stockItemId       String
  quantity          Int             @default(0)
  rate              Float           @default(0)
  totalValue        Float           @default(0)
  deliveredQuantity Int             @default(0)
  deliveredDate     String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  purchaseOrder     PurchaseOrder   @relation(fields: [poId], references: [id])
  stockItem         StockItem       @relation(fields: [stockItemId], references: [id])
  deliveryHistory   PODeliveryHistory[]
}

model PODeliveryHistory {
  id              String      @id @default(cuid())
  poLineItemId    String
  quantity        Int
  deliveryDate    String
  createdAt       DateTime    @default(now())
  poLineItem      POLineItem  @relation(fields: [poLineItemId], references: [id])
}

model CustomerPO {
  id          String      @id @default(cuid())
  categoryId  String
  projectNo   String?
  date        String?
  totalValue  Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category    @relation(fields: [categoryId], references: [id])
}
